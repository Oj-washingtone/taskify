# Taskify API Configuration
# Replace the value below with your actual local or production backend URL.
EXPO_PUBLIC_API_URL=http://localhost:3000

# Google OAuth Credentials
# You ONLY need the Web Client ID on the frontend to get the idToken for your backend.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your_web_client_id_here
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your_ios_client_id_here (Optional)
# EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your_android_client_id_here (Optional)
